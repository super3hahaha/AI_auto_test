{
  "_comment": "通用广告/弹窗清障规则库，供 `adbkit.py sweep` 读取。跨 App 通用、随仓库版本管理。每条规则：id 唯一标识；scope 作用页（子串匹配当前前台窗口组件串，'任意页面'/'*' 表示不限页）；action 目前只有 tap_matched（点命中控件中心）；match 选择器列表（按顺序试，第一个命中即点，by ∈ id/text/desc，partial 缺省 false=精确/id 后缀匹配，true=子串）；enabled 缺省 true。广告关闭类只在对应广告 SDK 全屏页触发（scope 卡住），text/desc 用 partial 兜住'Skip Ad'/'跳过广告 5s'这类带后缀的文案；权限/系统弹窗类作用页为任意页面、用精确 id。来源：同事共享的 ad-*/perm-*/system-* 规则。",
  "version": 1,
  "rules": [
    {
      "id": "ad-admob-close",
      "scope": "AdActivity",
      "action": "tap_matched",
      "match": [
        {"by": "id", "value": "close-button"},
        {"by": "desc", "value": "Interstitial close button"},
        {"by": "text", "value": "Skip", "partial": true},
        {"by": "text", "value": "Close", "partial": true},
        {"by": "text", "value": "Continue to app", "partial": true},
        {"by": "text", "value": "跳过", "partial": true},
        {"by": "text", "value": "关闭广告", "partial": true},
        {"by": "text", "value": "关闭", "partial": true},
        {"by": "desc", "value": "Skip", "partial": true},
        {"by": "desc", "value": "Close", "partial": true},
        {"by": "desc", "value": "Continue to app", "partial": true}
      ]
    },
    {
      "id": "ad-applovin-close",
      "scope": "AppLovinFullscreen",
      "action": "tap_matched",
      "match": [
        {"by": "id", "value": "close-button"},
        {"by": "text", "value": "Skip", "partial": true},
        {"by": "text", "value": "Close", "partial": true},
        {"by": "text", "value": "跳过", "partial": true},
        {"by": "text", "value": "关闭", "partial": true}
      ]
    },
    {
      "id": "ad-unity-close",
      "scope": "AdUnitActivity",
      "action": "tap_matched",
      "match": [
        {"by": "id", "value": "close-button"},
        {"by": "text", "value": "Skip", "partial": true},
        {"by": "text", "value": "Close", "partial": true},
        {"by": "text", "value": "跳过", "partial": true},
        {"by": "text", "value": "关闭", "partial": true}
      ]
    },
    {
      "id": "ad-fan-close",
      "scope": "AudienceNetwork",
      "action": "tap_matched",
      "match": [
        {"by": "id", "value": "close-button"},
        {"by": "text", "value": "Skip", "partial": true},
        {"by": "text", "value": "Close", "partial": true},
        {"by": "text", "value": "跳过", "partial": true},
        {"by": "text", "value": "关闭", "partial": true}
      ]
    },
    {
      "id": "ad-vungle-close",
      "scope": "VungleActivity",
      "action": "tap_matched",
      "match": [
        {"by": "id", "value": "close-button"},
        {"by": "text", "value": "Skip", "partial": true},
        {"by": "text", "value": "Close", "partial": true},
        {"by": "text", "value": "跳过", "partial": true},
        {"by": "text", "value": "关闭", "partial": true}
      ]
    },
    {
      "id": "perm-allow",
      "scope": "任意页面",
      "action": "tap_matched",
      "match": [
        {"by": "id", "value": "com.android.permissioncontroller:id/permission_allow_button"},
        {"by": "id", "value": "com.android.permissioncontroller:id/permission_allow_all_button"},
        {"by": "id", "value": "com.android.permissioncontroller:id/permission_allow_foreground_only_button"}
      ]
    },
    {
      "id": "perm-allow-all-files",
      "scope": "AppManageExternalStorageActivity",
      "action": "tap_matched",
      "match": [
        {"by": "text", "value": "Allow access to manage all files", "partial": true}
      ]
    },
    {
      "id": "system-immersive-cling",
      "scope": "任意页面",
      "action": "tap_matched",
      "match": [
        {"by": "id", "value": "com.android.systemui:id/ok"}
      ]
    }
  ]
}
