# 账号级凭证 + 本机状态（共享 config/，但这些不入库）
config/service_account.json
config/oauth_client.json
config/oauth_token*
config/active.json
# 本机/业务态：桌面壳资源库文本资源（含 App 专属 URL/文案）、本机设备别名映射（真实序列号）
# —— 都是具体业务/本机数据，不属于「框架 + 最小示例」，代码缺文件时兜底空
config/text_resources.json
config/device_aliases.json
evidence/*/
!evidence/.gitkeep
.dumpcache/
__pycache__/
*.pyc
# 本机专用虚拟环境（Python 3.11，替代系统 3.9 消 EOL 警告，见 gotchas.md）——各协作者本机自建
.venv/

.DS_Store

# 真实素材（版权/不可再生）不入库；每个协作者本地自备，见 assets/README.md
assets/*
!assets/README.md

# ── 多 App 工作区 apps/<slug>/（见 docs/decisions.md #27）──
# 每个 App 的 target.json（含 serial/sheet_id/run_id 等本机态）不入库
apps/*/target.json
# ledger 是本机执行产物（cases 可重新汇编、团队真值是 Google Sheet）——多人各自跑会冲突，不入库
apps/*/ledger/*
!apps/*/ledger/.gitkeep
# 完整业务用例集/固化脚本是重业务内容，只留最小示例，其余（含新增业务用例/脚本）一律不入库。
# 改用白名单：忽略 cases/flows 全部，仅放行示例（CUT-CORE-01 + _TEMPLATE + flow_cut_save）。
# 之前用逐文件黑名单，跟不上后续新增的业务用例，会漏网入库。
apps/*/cases/*
!apps/*/cases/CUT-CORE-01.yaml
!apps/*/cases/_TEMPLATE.yaml
apps/*/flows/*
!apps/*/flows/flow_cut_save.sh
# 桌面壳「删除 App」回收站（本机误删恢复用，不是业务内容）
apps/.trash/
# 留存的多版本 APK 本体（本机测试资产，体积大，不入库）
apps/*/apks/

# ── 桌面壳构建产物 ──
desktop/node_modules/
desktop/dist/
desktop/src-tauri/target/
