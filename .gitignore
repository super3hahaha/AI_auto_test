# 账号级凭证 + 本机状态（共享 config/，但这些不入库）
config/service_account.json
config/oauth_client.json
config/oauth_token*
config/active.json
evidence/*/
!evidence/.gitkeep
.dumpcache/
__pycache__/
*.pyc

.DS_Store

# 真实素材（版权/不可再生）不入库；每个协作者本地自备，见 assets/README.md
assets/*
!assets/README.md

# ── 多 App 工作区 apps/<slug>/（见 docs/decisions.md #27）──
# 每个 App 的 target.json（含 serial/sheet_id/run_id 等本机态）不入库
apps/*/target.json
# ledger 是本机执行产物（cases 可重新汇编、团队真值是 Google Sheet）——多人各自跑会冲突，不入库
apps/*/ledger/*
!apps/*/ledger/.gitkeep
# 完整业务用例集/暂缓用例/业务固化脚本是重业务内容，只留最小示例（CUT-CORE-01 + flow_cut_save），其余不入库
apps/*/cases/regression.yaml
apps/*/cases/_parked_regression.yaml
apps/*/flows/flow_cut_edge_wav40000.sh

# ── 桌面壳构建产物 ──
desktop/node_modules/
desktop/dist/
desktop/src-tauri/target/
